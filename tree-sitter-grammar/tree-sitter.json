{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "row",
      "camelcase": "Row",
      "title": "Row",
      "scope": "source.row",
      "file-types": [
        "row"
      ],
      "injection-regex": "^row$",
      "class-name": "TreeSitterRow"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Experimental functional language with records and effects using Row Polymorphism.",
    "authors": [
      {
        "name": "Kris Chambers",
        "email": "kris.chambers@outlook.com"
      }
    ],
    "links": {
      "repository": "https://github.com/KrisChambers/row"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
