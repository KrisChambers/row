effect Counter {
  put : Int -> (),
  get : () -> Int
}

let main =
  let
    test = \unused ->
        let s1 = perform Counter.put 1 in
        let s2 = perform Counter.put 2 in
        let s3 = perform Counter.put 3 in
        let s4 = perform Counter.put 4 in
perform Counter.get ()
  in (handle (test ()) with {
      return x -> \s -> x,
      Counter.get k -> \s -> (k s) s,
      Counter.put v k -> \s -> (k ()) v
    }) 0
